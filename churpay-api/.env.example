# ChurPay API environment (sample values only)
NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://user:password@host:5432/churpay
PUBLIC_BASE_URL=https://api.churpay.com
PUBLIC_WEB_BASE_URL=https://churpay.com
JWT_SECRET=replace-with-a-long-random-secret
SUPER_ROUTES_ENABLED=true
PAYFAST_MODE=sandbox
# Church-level PayFast credentials are stored encrypted in DB when admins connect in portal.
# This key is mandatory for /api/churches/payfast/connect.
PAYFAST_CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-random-secret
# Optional global fallback merchant credentials (legacy).
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_GLOBAL_FALLBACK_ENABLED=false
PAYFAST_RETURN_URL=https://api.churpay.com/api/payfast/return
PAYFAST_CANCEL_URL=https://api.churpay.com/api/payfast/cancel
PAYFAST_NOTIFY_URL=https://api.churpay.com/webhooks/payfast/itn
APP_DEEP_LINK_BASE=churpaydemo://give
PAYFAST_APP_FALLBACK_URL=https://www.churpay.com
PGSSLINSECURE=false
DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----\nREPLACE_WITH_DO_CA_CERT\n-----END CERTIFICATE-----
TRUST_PROXY=true
TRUST_PROXY_HOPS=1

# Comma-separated browser origins allowed by CORS in production
# include every browser origin that will call this API (admin web/app web)
CORS_ORIGINS=https://www.churpay.com,https://churpay.com

# Email delivery (used for church onboarding admin email verification)
# Modes:
# - MAIL_DELIVERY_MODE=resend   (recommended for production)
# - MAIL_DELIVERY_MODE=webhook  (POST to EMAIL_WEBHOOK_URL)
# - MAIL_DELIVERY_MODE=log      (prints emails to stdout/PM2 logs)
# If MAIL_DELIVERY_MODE is empty, the API auto-selects resend/webhook/log based on which env vars are present.
MAIL_DELIVERY_MODE=
MAIL_FROM="Churpay <no-reply@churpay.com>"
RESEND_API_KEY=
EMAIL_WEBHOOK_URL=
# If true, email failures will NOT fall back to log mode (recommended for production so users don't get stuck).
EMAIL_DELIVERY_REQUIRED=false

# Login two-factor for admin/super portals
ADMIN_LOGIN_2FA_ENABLED=true
SUPER_LOGIN_2FA_ENABLED=true
LOGIN_2FA_TTL_MINUTES=15
LOGIN_2FA_MAX_ATTEMPTS=5

# Push notifications (Expo)
# - PUSH_PROVIDER=log   (default: prints payloads to PM2 logs)
# - PUSH_PROVIDER=expo  (send real push notifications via Expo push service)
PUSH_PROVIDER=log
# Optional: Expo access token (recommended). Push can still work without it for basic usage.
EXPO_ACCESS_TOKEN=

# Scheduled notification jobs (birthdays + Saturday cash reminder)
# Runs inside the API process when enabled.
NOTIFICATION_JOBS_ENABLED=false
NOTIFICATION_JOBS_INTERVAL_MS=900000
NOTIFICATION_TIMEZONE=Africa/Johannesburg
BIRTHDAY_NOTIFICATIONS_ENABLED=true
CASH_SATURDAY_REMINDER_ENABLED=false
CASH_SATURDAY_REMINDER_HOUR_LOCAL=19

# Dangerous: allow super admin to permanently purge test churches/members and their data.
# Keep this OFF in production except for controlled one-off cleanups.
DATA_PURGE_ENABLED=false

# Basic in-memory API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
DEMO_MODE=false
PLATFORM_FEE_FIXED=2.50
PLATFORM_FEE_PCT=0.0075
SUPERADMIN_CUT_PCT=1.0

# Optional: super-admin login for /api/super/login
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=change-me

# Optional defaults for seed:admin script
SEED_CHURCH_NAME=Great Commission Church of Christ
SEED_JOIN_CODE=GCCOC-1234
SEED_ADMIN_NAME=Admin Test
SEED_ADMIN_PHONE=0710000000
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=test123
