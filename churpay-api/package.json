{
  "name": "churpay-api",
  "version": "1.0.0",
  "type": "module",
  "description": "API for Churpay",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed:admin": "node scripts/seed-admin.mjs",
    "migrate": "node scripts/run-migrations.mjs",
    "migrate:check": "node scripts/run-migrations.mjs --check",
    "migrate:lint": "node scripts/check-migrations.mjs",
    "migrate:drift": "node scripts/check-migrations.js",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "rollback:prod": "bash scripts/rollback-prod.sh",
    "test": "node --test tests/*.integration.test.mjs"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
